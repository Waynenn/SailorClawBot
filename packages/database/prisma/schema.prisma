generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id                  String               @id
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             GuildMember[]
  profiles            Profile[]
  wallets             Wallet[]
  families            Family[]
  tickets             Ticket[]
  warnings            Warning[]
  mutes               Mute[]
  bans                Ban[]
  cases               Case[]
  permissionOverrides PermissionOverride[]
  caseCounter         GuildCaseCounter?
}

model GuildMember {
  guildId  String
  userId   String
  joinedAt DateTime @default(now())
  guild    Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([guildId, userId])
}

model Profile {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model Wallet {
  id           String        @id @default(cuid())
  guildId      String
  userId       String
  balance      BigInt        @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  guild        Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([guildId, userId])
}

model Transaction {
  id        String   @id @default(cuid())
  walletId  String
  amount    BigInt
  reason    String
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Family {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  ownerUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, name])
}

model Ticket {
  id             String       @id @default(cuid())
  guildId        String
  openedByUserId String
  channelId      String?
  status         TicketStatus @default(open)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  guild          Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

enum TicketStatus {
  open
  closed
}

// ============================================================================
// MODERATION
// ============================================================================

enum ModerationType {
  warning
  mute
  ban
  kick
}

model Warning {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  reason      String
  moderatorId String
  caseNumber  Int
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId, userId])
}

model Mute {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  reason      String?
  moderatorId String
  caseNumber  Int
  duration    Int // minutes
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId, userId])
  @@index([guildId, isActive])
  @@index([expiresAt])
}

model Ban {
  id          String    @id @default(cuid())
  guildId     String
  userId      String
  reason      String
  moderatorId String
  caseNumber  Int
  expiresAt   DateTime? // null = permanent
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId, userId])
  @@index([guildId, isActive])
}

model Case {
  id           String         @id @default(cuid())
  guildId      String
  caseNumber   Int
  type         ModerationType
  userId       String
  moderatorId  String
  action       String // reference to Warning/Mute/Ban id
  reason       String?
  metadata     Json?
  isAppealed   Boolean        @default(false)
  appealReason String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  guild        Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId, userId])
}

model PermissionOverride {
  id         String  @id @default(cuid())
  guildId    String
  userId     String
  permission String
  allowed    Boolean
  guild      Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, permission])
  @@index([guildId, userId])
}

// Per-guild atomic counter for sequential, human-readable case numbers.
// Incremented via upsert+increment to stay race-safe under concurrent moderation.
model GuildCaseCounter {
  guildId    String @id
  lastNumber Int    @default(0)
  guild      Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
}
