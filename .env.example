# ============================================================================
# SailorClawBot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE
# PostgreSQL connection string for Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local dev (Docker): see infrastructure/docker-compose.yml
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sailorclaw?schema=public"

# ----------------------------------------------------------------------------
# DISCORD BOT
# Obtain from https://discord.com/developers/applications
# Bot token — keep secret, rotate immediately if leaked.
# Client ID — public, used to generate invite links.
# ----------------------------------------------------------------------------
DISCORD_TOKEN="your-bot-token-here"
DISCORD_CLIENT_ID="your-client-id-here"

# Optional: restrict slash-command registration to one guild during dev.
# Leave empty to register commands globally (takes up to 1 hour to propagate).
DISCORD_DEV_GUILD_ID=""

# ----------------------------------------------------------------------------
# ENVIRONMENT
# NODE_ENV: development | production | test
# LOG_LEVEL: debug | info | warn | error
# ----------------------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"
