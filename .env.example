# ─────────────────────────────────────────────
# Discord Application
# ─────────────────────────────────────────────

# Token from https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Application / Client ID (from General Information)
DISCORD_CLIENT_ID=your_client_id_here

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────

# docker-compose default credentials match the values below
DATABASE_URL=postgresql://sailorclaw:change_me@localhost:5432/sailorclawbot

# ─────────────────────────────────────────────
# Error Tracking (optional)
# ─────────────────────────────────────────────

# Create a project at https://sentry.io and paste the DSN here
# Leave blank to disable Sentry
SENTRY_DSN=

# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────

NODE_ENV=development
